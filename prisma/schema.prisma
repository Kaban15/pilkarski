generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// TURNIEJE — ENUMS
// ============================================================

enum TournamentFormat {
  GROUP_STAGE
  KNOCKOUT
  GROUP_AND_KNOCKOUT
}

enum TournamentStatus {
  REGISTRATION
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum TournamentTeamStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum TournamentMatchPhase {
  GROUP
  ROUND_OF_16
  QUARTER_FINAL
  SEMI_FINAL
  THIRD_PLACE
  FINAL
}

// ============================================================
// REGIONY I HIERARCHIA LIGOWA
// ============================================================

model Region {
  id   Int    @id @default(autoincrement())
  name String @unique // "Wielkopolski ZPN"
  slug String @unique // "wielkopolski-zpn"

  leagueLevels LeagueLevel[]
  clubs        Club[]
  players      Player[]
  coaches      Coach[]
  sparingOffers SparingOffer[]
  events       Event[]
  transfers    Transfer[]
  tournaments  Tournament[]

  @@map("regions")
}

model LeagueLevel {
  id       Int    @id @default(autoincrement())
  regionId Int    @map("region_id")
  name     String // "Klasa A"
  tier     Int    // 1 = najwyższy regionalnie

  region Region       @relation(fields: [regionId], references: [id])
  groups LeagueGroup[]

  @@unique([regionId, name])
  @@map("league_levels")
}

model LeagueGroup {
  id            Int    @id @default(autoincrement())
  leagueLevelId Int    @map("league_level_id")
  name          String // "Grupa 2"

  leagueLevel LeagueLevel @relation(fields: [leagueLevelId], references: [id])
  clubs       Club[]

  @@unique([leagueLevelId, name])
  @@map("league_groups")
}

// ============================================================
// UŻYTKOWNICY
// ============================================================

enum UserRole {
  CLUB
  PLAYER
  COACH
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  club                     Club?
  player                   Player?
  coach                    Coach?
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  notifications            Notification[]
  favorites                Favorite[]
  transfers                Transfer[]
  points                   UserPoints[]
  badges                   UserBadge[]
  pushSubscriptions        PushSubscription[]
  followedClubs            ClubFollower[]
  clubMemberships          ClubMembership[]
  eventAttendance          EventAttendance[]
  goals                    MatchGoal[]
  tournaments              Tournament[]
  tournamentTeams          TournamentTeam[]
  tournamentGoals          TournamentGoal[]

  @@map("users")
}

// ============================================================
// PROFILE
// ============================================================

model Club {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @unique @map("user_id") @db.Uuid
  name          String  @db.VarChar(200)
  logoUrl       String? @map("logo_url") @db.VarChar(500)
  description   String?
  city          String? @db.VarChar(100)
  regionId      Int?    @map("region_id")
  leagueGroupId Int?    @map("league_group_id")
  contactEmail  String? @map("contact_email") @db.VarChar(255)
  contactPhone  String? @map("contact_phone") @db.VarChar(20)
  website       String? @db.VarChar(300)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  region               Region?               @relation(fields: [regionId], references: [id])
  leagueGroup          LeagueGroup?          @relation(fields: [leagueGroupId], references: [id])
  sparingOffers        SparingOffer[]
  sparingApplications  SparingApplication[]
  invitationsSent      SparingInvitation[]   @relation("InvitationsSent")
  invitationsReceived  SparingInvitation[]   @relation("InvitationsReceived")
  events               Event[]
  reviewsGiven         Review[]              @relation("ReviewsGiven")
  reviewsReceived      Review[]              @relation("ReviewsReceived")
  followers            ClubFollower[]
  recruitmentPipeline  RecruitmentPipeline[]
  posts                ClubPost[]
  memberships          ClubMembership[]
  lineups              TeamLineup[]
  groupChat            Conversation?
  tournamentTeams      TournamentTeam[]

  @@map("clubs")
}

enum FootPreference {
  LEFT
  RIGHT
  BOTH
}

enum PlayerPosition {
  GK
  CB
  LB
  RB
  CDM
  CM
  CAM
  LM
  RM
  LW
  RW
  ST
}

model Player {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @unique @map("user_id") @db.Uuid
  firstName         String          @map("first_name") @db.VarChar(100)
  lastName          String          @map("last_name") @db.VarChar(100)
  dateOfBirth       DateTime?       @map("date_of_birth") @db.Date
  photoUrl          String?         @map("photo_url") @db.VarChar(500)
  city              String?         @db.VarChar(100)
  regionId          Int?            @map("region_id")
  heightCm          Int?            @map("height_cm")
  weightKg          Int?            @map("weight_kg")
  preferredFoot     FootPreference? @map("preferred_foot")
  primaryPosition   PlayerPosition? @map("primary_position")
  secondaryPosition PlayerPosition? @map("secondary_position")
  bio               String?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  region            Region?           @relation(fields: [regionId], references: [id])
  careerEntries     CareerEntry[]
  eventApplications EventApplication[]

  @@map("players")
}

model Coach {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @unique @map("user_id") @db.Uuid
  firstName      String   @map("first_name") @db.VarChar(100)
  lastName       String   @map("last_name") @db.VarChar(100)
  specialization String?  @db.VarChar(100)
  level          String?  @db.VarChar(50)
  city           String?  @db.VarChar(100)
  regionId       Int?     @map("region_id")
  bio            String?
  photoUrl       String?  @map("photo_url") @db.VarChar(500)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  region        Region?            @relation(fields: [regionId], references: [id])
  events        Event[]
  careerEntries CoachCareerEntry[]

  @@map("coaches")
}

model CoachCareerEntry {
  id        String   @id @default(uuid()) @db.Uuid
  coachId   String   @map("coach_id") @db.Uuid
  clubName  String   @map("club_name") @db.VarChar(200)
  season    String   @db.VarChar(20)
  role      String   @db.VarChar(100)
  level     String?  @db.VarChar(100)
  notes     String?  @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  coach Coach @relation(fields: [coachId], references: [id], onDelete: Cascade)

  @@map("coach_career_entries")
}

model CareerEntry {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  clubName  String   @map("club_name") @db.VarChar(200)
  season    String   @db.VarChar(20) // "2024/2025"
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("career_entries")
}

// ============================================================
// SPARINGI
// ============================================================

enum SparingLevel {
  YOUTH       // Młodzieżowy
  AMATEUR     // Amatorski
  SEMI_PRO    // Półprofesjonalny
  PRO         // Profesjonalny
}

enum AgeCategory {
  JUNIOR_E    // Żak (U-8/U-9)
  JUNIOR_D    // Orlik (U-10/U-11)
  JUNIOR_C    // Młodzik (U-12/U-13)
  JUNIOR_B    // Trampkarz (U-14/U-15)
  JUNIOR_A    // Junior młodszy (U-16/U-17)
  SENIOR_JR   // Junior (U-18/U-19)
  SENIOR      // Senior
  VETERAN     // Oldboj (35+)
}

enum SparingStatus {
  OPEN
  MATCHED
  CANCELLED
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  COUNTER_PROPOSED
  ACCEPTED
  REJECTED
}

model SparingOffer {
  id            String        @id @default(uuid()) @db.Uuid
  clubId        String        @map("club_id") @db.Uuid
  title         String        @db.VarChar(300)
  description   String?
  matchDate     DateTime      @map("match_date") @db.Timestamptz
  location      String?       @db.VarChar(300)
  lat           Decimal?      @db.Decimal(9, 6)
  lng           Decimal?      @db.Decimal(9, 6)
  costSplitInfo String?       @map("cost_split_info") @db.VarChar(500)
  level         SparingLevel? @map("level")
  ageCategory   AgeCategory?  @map("age_category")
  preferredTime String?       @map("preferred_time") @db.VarChar(100)
  status           SparingStatus @default(OPEN)
  regionId         Int?          @map("region_id")
  homeScore        Int?          @map("home_score")
  awayScore        Int?          @map("away_score")
  scoreSubmittedBy String?       @map("score_submitted_by") @db.Uuid
  scoreConfirmed   Boolean       @default(false) @map("score_confirmed")
  costPerTeam      Int?          @map("cost_per_team")
  costPaidHome     Boolean       @default(false) @map("cost_paid_home")
  costPaidAway     Boolean       @default(false) @map("cost_paid_away")
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  club         Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  region       Region?              @relation(fields: [regionId], references: [id])
  applications SparingApplication[]
  invitations  SparingInvitation[]
  favorites    Favorite[]
  reviews      Review[]
  goals        MatchGoal[]

  @@index([regionId, status])
  @@index([matchDate])
  @@map("sparing_offers")
}

model SparingApplication {
  id                   String            @id @default(uuid()) @db.Uuid
  sparingOfferId       String            @map("sparing_offer_id") @db.Uuid
  applicantClubId      String            @map("applicant_club_id") @db.Uuid
  message              String?
  counterProposedDate  DateTime?         @map("counter_proposed_date") @db.Timestamptz
  status               ApplicationStatus @default(PENDING)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  sparingOffer  SparingOffer @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  applicantClub Club         @relation(fields: [applicantClubId], references: [id], onDelete: Cascade)

  @@unique([sparingOfferId, applicantClubId])
  @@map("sparing_applications")
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

model SparingInvitation {
  id              String           @id @default(uuid()) @db.Uuid
  sparingOfferId  String           @map("sparing_offer_id") @db.Uuid
  fromClubId      String           @map("from_club_id") @db.Uuid
  toClubId        String           @map("to_club_id") @db.Uuid
  message         String?
  status          InvitationStatus @default(PENDING)
  expiresAt       DateTime?        @map("expires_at") @db.Timestamptz
  createdAt       DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  sparingOffer SparingOffer @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  fromClub     Club         @relation("InvitationsSent", fields: [fromClubId], references: [id], onDelete: Cascade)
  toClub       Club         @relation("InvitationsReceived", fields: [toClubId], references: [id], onDelete: Cascade)

  @@unique([sparingOfferId, toClubId])
  @@index([toClubId, status])
  @@map("sparing_invitations")
}

// ============================================================
// WYDARZENIA
// ============================================================

enum EventType {
  OPEN_TRAINING
  RECRUITMENT
  TRYOUT
  CAMP
  CONTINUOUS_RECRUITMENT
  INDIVIDUAL_TRAINING     // Trening indywidualny
  GROUP_TRAINING          // Trening w małej grupie
}

enum EventVisibility {
  PUBLIC
  INTERNAL
}

enum AttendanceStatus {
  YES
  NO
  MAYBE
}

model Event {
  id              String    @id @default(uuid()) @db.Uuid
  clubId          String?   @map("club_id") @db.Uuid
  coachId         String?   @map("coach_id") @db.Uuid
  type            EventType
  title           String    @db.VarChar(300)
  description     String?
  eventDate       DateTime  @map("event_date") @db.Timestamptz
  location        String?   @db.VarChar(300)
  lat             Decimal?  @db.Decimal(9, 6)
  lng             Decimal?  @db.Decimal(9, 6)
  maxParticipants  Int?            @map("max_participants")
  regionId         Int?            @map("region_id")
  targetPosition   PlayerPosition? @map("target_position")
  targetAgeMin     Int?            @map("target_age_min")
  targetAgeMax     Int?            @map("target_age_max")
  targetLevel      SparingLevel?   @map("target_level")
  priceInfo        String?         @map("price_info") @db.VarChar(200)
  costPerPerson    Int?            @map("cost_per_person")
  visibility       EventVisibility @default(PUBLIC) @map("visibility")
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  club         Club?              @relation(fields: [clubId], references: [id], onDelete: Cascade)
  coach        Coach?             @relation(fields: [coachId], references: [id], onDelete: Cascade)
  region       Region?            @relation(fields: [regionId], references: [id])
  applications EventApplication[]
  favorites    Favorite[]
  attendance   EventAttendance[]

  @@index([regionId, type])
  @@index([eventDate])
  @@map("events")
}

model EventAttendance {
  id        String           @id @default(uuid()) @db.Uuid
  eventId   String           @map("event_id") @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  status    AttendanceStatus
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@map("event_attendance")
}

model EventApplication {
  id        String            @id @default(uuid()) @db.Uuid
  eventId   String            @map("event_id") @db.Uuid
  playerId  String            @map("player_id") @db.Uuid
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
  @@map("event_applications")
}

// ============================================================
// POWIADOMIENIA
// ============================================================

enum NotificationType {
  SPARING_APPLICATION    // ktoś zaaplikował na Twój sparing
  SPARING_ACCEPTED       // Twoja aplikacja zaakceptowana
  SPARING_REJECTED       // Twoja aplikacja odrzucona
  EVENT_APPLICATION      // ktoś zgłosił się na Twoje wydarzenie
  EVENT_ACCEPTED         // Twoje zgłoszenie zaakceptowane
  EVENT_REJECTED         // Twoje zgłoszenie odrzucone
  NEW_MESSAGE            // nowa wiadomość
  NEW_REVIEW             // nowa recenzja po sparingu
  RECRUITMENT_NEW        // obserwowany klub otworzył nabór/testy/camp
  RECRUITMENT_MATCH      // nabór w Twoim regionie na Twoją pozycję
  REMINDER               // przypomnienie o aktywności
  SPARING_INVITATION     // zaproszenie na sparing od innego klubu
  MEMBERSHIP_REQUEST     // prośba o dołączenie do klubu
  MEMBERSHIP_ACCEPTED    // akceptacja prośby o dołączenie
  SCORE_SUBMITTED        // wynik wpisany — czeka na potwierdzenie
  SCORE_CONFIRMED        // wynik potwierdzony
  SCORE_REJECTED         // wynik odrzucony
  GOAL_ADDED             // bramka w meczu
  CLUB_INVITATION        // zaproszenie do kadry klubu
  TOURNAMENT_APPLICATION
  TOURNAMENT_ACCEPTED
  TOURNAMENT_REJECTED
  TOURNAMENT_STARTED
  TOURNAMENT_SCORE_SUBMITTED
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(300)
  message   String?          @db.VarChar(500)
  link      String?          @db.VarChar(500)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// WIADOMOŚCI
// ============================================================

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  clubId    String?  @unique @map("club_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  club         Club?                    @relation(fields: [clubId], references: [id], onDelete: Cascade)
  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String @map("conversation_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  content        String
  readAt         DateTime? @map("read_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

// ============================================================
// PUSH SUBSCRIPTIONS
// ============================================================

model PushSubscription {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  endpoint  String   @db.VarChar(500)
  p256dh    String   @db.VarChar(200)
  auth      String   @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@map("push_subscriptions")
}

// ============================================================
// GAMIFIKACJA
// ============================================================

model UserPoints {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  points    Int      @default(0)
  action    String   @db.VarChar(50) // np. "sparing_created", "review_given"
  refId     String?  @map("ref_id") @db.Uuid // ID powiązanego obiektu
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("user_points")
}

model UserBadge {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  badge     String   @db.VarChar(50) // klucz odznaki
  awardedAt DateTime @default(now()) @map("awarded_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, badge])
  @@map("user_badges")
}

// ============================================================
// TRANSFERY / OGŁOSZENIA
// ============================================================

enum TransferType {
  LOOKING_FOR_CLUB    // zawodnik szuka klubu
  LOOKING_FOR_PLAYER  // klub szuka zawodnika
  FREE_AGENT          // wolny agent
}

enum TransferStatus {
  ACTIVE
  CLOSED
}

model Transfer {
  id             String          @id @default(uuid()) @db.Uuid
  userId         String          @map("user_id") @db.Uuid
  type           TransferType
  status         TransferStatus  @default(ACTIVE)
  title          String          @db.VarChar(300)
  description    String?
  position       PlayerPosition? // szukana/oferowana pozycja
  regionId       Int?            @map("region_id")
  minAge         Int?            @map("min_age")
  maxAge         Int?            @map("max_age")
  availableFrom  DateTime?       @map("available_from") @db.Date
  preferredLevel SparingLevel?   @map("preferred_level")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  region          Region?               @relation(fields: [regionId], references: [id])
  pipelineEntries RecruitmentPipeline[]

  @@index([type, status])
  @@index([regionId])
  @@index([position])
  @@map("transfers")
}

// ============================================================
// PIPELINE REKRUTACYJNY
// ============================================================

enum RecruitmentStage {
  WATCHING           // Na radarze
  INVITED_TO_TRYOUT  // Zaproszony na testy
  AFTER_TRYOUT       // Po testach
  OFFER_SENT         // Oferta wysłana
  SIGNED             // Podpisany
  REJECTED           // Odrzucony
}

model RecruitmentPipeline {
  id         String           @id @default(uuid()) @db.Uuid
  clubId     String           @map("club_id") @db.Uuid
  transferId String           @map("transfer_id") @db.Uuid
  stage      RecruitmentStage @default(WATCHING)
  position   Int              @default(0)
  notes      String?
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  club     Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  transfer Transfer           @relation(fields: [transferId], references: [id], onDelete: Cascade)
  events   RecruitmentEvent[]

  @@unique([clubId, transferId])
  @@index([clubId, stage])
  @@map("recruitment_pipeline")
}

model RecruitmentEvent {
  id         String           @id @default(uuid()) @db.Uuid
  pipelineId String           @map("pipeline_id") @db.Uuid
  fromStage  RecruitmentStage? @map("from_stage")
  toStage    RecruitmentStage @map("to_stage")
  note       String?
  createdAt  DateTime         @default(now()) @map("created_at") @db.Timestamptz

  pipeline RecruitmentPipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId])
  @@map("recruitment_events")
}

// ============================================================
// RECENZJE
// ============================================================

model Review {
  id              String       @id @default(uuid()) @db.Uuid
  sparingOfferId  String       @map("sparing_offer_id") @db.Uuid
  reviewerClubId  String       @map("reviewer_club_id") @db.Uuid
  reviewedClubId  String       @map("reviewed_club_id") @db.Uuid
  rating          Int          // 1-5
  comment         String?
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz

  sparingOffer SparingOffer @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  reviewerClub Club         @relation("ReviewsGiven", fields: [reviewerClubId], references: [id], onDelete: Cascade)
  reviewedClub Club         @relation("ReviewsReceived", fields: [reviewedClubId], references: [id], onDelete: Cascade)

  @@unique([sparingOfferId, reviewerClubId])
  @@index([reviewedClubId])
  @@map("reviews")
}

// ============================================================
// ULUBIONE
// ============================================================

model Favorite {
  id             String        @id @default(uuid()) @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  sparingOfferId String?       @map("sparing_offer_id") @db.Uuid
  eventId        String?       @map("event_id") @db.Uuid
  clubPostId     String?       @map("club_post_id") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  sparingOffer SparingOffer? @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  event        Event?        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  clubPost     ClubPost?     @relation(fields: [clubPostId], references: [id], onDelete: Cascade)

  @@unique([userId, sparingOfferId])
  @@unique([userId, eventId])
  @@unique([userId, clubPostId])
  @@index([userId])
  @@map("favorites")
}

// ============================================================
// AKTUALNOŚCI KLUBOWE (COMMUNITY)
// ============================================================

enum ClubPostCategory {
  LOOKING_FOR_GOALKEEPER   // Szukamy bramkarza
  LOOKING_FOR_SPARRING     // Szukamy sparingpartnera
  LOOKING_FOR_COACH        // Szukamy trenera
  GENERAL_NEWS             // Aktualność ogólna
  MATCH_RESULT             // Wynik meczu
  INTERNAL                 // Wewnętrzne (tylko członkowie klubu)
}

model ClubPost {
  id        String           @id @default(uuid()) @db.Uuid
  clubId    String           @map("club_id") @db.Uuid
  category  ClubPostCategory
  title     String           @db.VarChar(300)
  content   String?
  expiresAt DateTime?        @map("expires_at") @db.Timestamptz
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  club      Club       @relation(fields: [clubId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([clubId, createdAt])
  @@index([category])
  @@map("club_posts")
}

// ============================================================
// CZŁONKOSTWO W KLUBIE
// ============================================================

enum MemberType {
  PLAYER
  COACH
}

enum MembershipStatus {
  PENDING
  INVITED
  ACCEPTED
  REJECTED
  LEFT
  REMOVED
}

model ClubMembership {
  id           String           @id @default(uuid()) @db.Uuid
  clubId       String           @map("club_id") @db.Uuid
  memberUserId String           @map("member_user_id") @db.Uuid
  memberType   MemberType       @map("member_type")
  status       MembershipStatus @default(PENDING)
  message      String?
  acceptedAt      DateTime?        @map("accepted_at") @db.Timestamptz
  canManageEvents Boolean          @default(false) @map("can_manage_events")
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  club       Club @relation(fields: [clubId], references: [id], onDelete: Cascade)
  memberUser User @relation(fields: [memberUserId], references: [id], onDelete: Cascade)

  @@unique([clubId, memberUserId])
  @@index([clubId, status])
  @@index([memberUserId, status])
  @@map("club_memberships")
}

// ============================================================
// SKŁADY MECZOWE
// ============================================================

enum LineupRole {
  STARTER
  BENCH
}

model TeamLineup {
  id       String   @id @default(uuid()) @db.Uuid
  clubId   String   @map("club_id") @db.Uuid
  title    String   @db.VarChar(300)
  matchInfo String? @map("match_info") @db.VarChar(500)
  date     DateTime @db.Timestamptz
  notes    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  club    Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  players TeamLineupPlayer[]

  @@index([clubId, date])
  @@map("team_lineups")
}

model TeamLineupPlayer {
  id           String     @id @default(uuid()) @db.Uuid
  lineupId     String     @map("lineup_id") @db.Uuid
  memberUserId String     @map("member_user_id") @db.Uuid
  role         LineupRole @default(STARTER)
  position     String?    @db.VarChar(10)
  notes        String?

  lineup     TeamLineup @relation(fields: [lineupId], references: [id], onDelete: Cascade)

  @@unique([lineupId, memberUserId])
  @@map("team_lineup_players")
}

// ============================================================
// OBSERWOWANIE KLUBÓW
// ============================================================

model ClubFollower {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  clubId    String   @map("club_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  club Club @relation(fields: [clubId], references: [id], onDelete: Cascade)

  @@unique([userId, clubId])
  @@index([clubId])
  @@map("club_followers")
}

// ============================================================
// BRAMKI MECZOWE
// ============================================================

model MatchGoal {
  id              String        @id @default(uuid()) @db.Uuid
  sparingOfferId  String        @map("sparing_offer_id") @db.Uuid
  scorerUserId    String        @map("scorer_user_id") @db.Uuid
  minute          Int?
  ownGoal         Boolean       @default(false) @map("own_goal")
  createdAt       DateTime      @default(now()) @map("created_at") @db.Timestamptz

  sparingOffer    SparingOffer  @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  scorerUser      User          @relation(fields: [scorerUserId], references: [id], onDelete: Cascade)

  @@index([sparingOfferId])
  @@map("match_goals")
}

// ============================================================
// TURNIEJE
// ============================================================

model Tournament {
  id               String           @id @default(uuid()) @db.Uuid
  creatorUserId    String           @map("creator_user_id") @db.Uuid
  title            String           @db.VarChar(300)
  description      String?
  startDate        DateTime         @map("start_date") @db.Timestamptz
  endDate          DateTime?        @map("end_date") @db.Timestamptz
  location         String?          @db.VarChar(300)
  lat              Decimal?         @db.Decimal(9, 6)
  lng              Decimal?         @db.Decimal(9, 6)
  regionId         Int?             @map("region_id")
  format           TournamentFormat
  maxTeams         Int              @map("max_teams")
  groupCount       Int              @default(1) @map("group_count")
  advancingPerGroup Int             @default(2) @map("advancing_per_group")
  status           TournamentStatus @default(REGISTRATION)
  costPerTeam      Int?             @map("cost_per_team")
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  creator    User               @relation(fields: [creatorUserId], references: [id])
  region     Region?            @relation(fields: [regionId], references: [id])
  teams      TournamentTeam[]
  matches    TournamentMatch[]
  standings  TournamentStanding[]

  @@index([status])
  @@index([regionId])
  @@map("tournaments")
}

model TournamentTeam {
  id           String               @id @default(uuid()) @db.Uuid
  tournamentId String               @map("tournament_id") @db.Uuid
  clubId       String?              @map("club_id") @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  teamName     String               @map("team_name") @db.VarChar(200)
  status       TournamentTeamStatus @default(PENDING)
  groupLabel   String?              @map("group_label") @db.VarChar(2)
  seed         Int?
  message      String?
  costPaid     Boolean              @default(false) @map("cost_paid")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz

  tournament    Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  club          Club?               @relation(fields: [clubId], references: [id])
  user          User                @relation(fields: [userId], references: [id])
  homeMatches   TournamentMatch[]   @relation("HomeTeam")
  awayMatches   TournamentMatch[]   @relation("AwayTeam")
  standings     TournamentStanding[]

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@map("tournament_teams")
}

model TournamentMatch {
  id           String               @id @default(uuid()) @db.Uuid
  tournamentId String               @map("tournament_id") @db.Uuid
  homeTeamId   String               @map("home_team_id") @db.Uuid
  awayTeamId   String               @map("away_team_id") @db.Uuid
  phase        TournamentMatchPhase
  groupLabel   String?              @map("group_label") @db.VarChar(2)
  round        Int?
  matchOrder   Int                  @default(0) @map("match_order")
  matchDate    DateTime?            @map("match_date") @db.Timestamptz
  location     String?              @db.VarChar(300)
  homeScore    Int?                 @map("home_score")
  awayScore    Int?                 @map("away_score")
  penaltyHome  Int?                 @map("penalty_home")
  penaltyAway  Int?                 @map("penalty_away")
  scoreSubmittedBy String?          @map("score_submitted_by") @db.Uuid
  scoreConfirmed   Boolean          @default(false) @map("score_confirmed")
  createdAt    DateTime             @default(now()) @map("created_at") @db.Timestamptz

  tournament   Tournament          @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  homeTeam     TournamentTeam      @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam     TournamentTeam      @relation("AwayTeam", fields: [awayTeamId], references: [id])
  goals        TournamentGoal[]

  @@index([tournamentId])
  @@map("tournament_matches")
}

model TournamentGoal {
  id           String          @id @default(uuid()) @db.Uuid
  matchId      String          @map("match_id") @db.Uuid
  scorerUserId String          @map("scorer_user_id") @db.Uuid
  minute       Int?
  ownGoal      Boolean         @default(false) @map("own_goal")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz

  match        TournamentMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  scorerUser   User            @relation(fields: [scorerUserId], references: [id])

  @@index([matchId])
  @@map("tournament_goals")
}

model TournamentStanding {
  id           String         @id @default(uuid()) @db.Uuid
  tournamentId String         @map("tournament_id") @db.Uuid
  teamId       String         @map("team_id") @db.Uuid
  groupLabel   String         @map("group_label") @db.VarChar(2)
  played       Int            @default(0)
  won          Int            @default(0)
  drawn        Int            @default(0)
  lost         Int            @default(0)
  goalsFor     Int            @default(0) @map("goals_for")
  goalsAgainst Int            @default(0) @map("goals_against")
  points       Int            @default(0)

  tournament   Tournament     @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  team         TournamentTeam @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, teamId])
  @@index([tournamentId, groupLabel])
  @@map("tournament_standings")
}
