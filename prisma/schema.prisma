generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// REGIONY I HIERARCHIA LIGOWA
// ============================================================

model Region {
  id   Int    @id @default(autoincrement())
  name String @unique // "Wielkopolski ZPN"
  slug String @unique // "wielkopolski-zpn"

  leagueLevels LeagueLevel[]
  clubs        Club[]
  players      Player[]
  sparingOffers SparingOffer[]
  events       Event[]

  @@map("regions")
}

model LeagueLevel {
  id       Int    @id @default(autoincrement())
  regionId Int    @map("region_id")
  name     String // "Klasa A"
  tier     Int    // 1 = najwyższy regionalnie

  region Region       @relation(fields: [regionId], references: [id])
  groups LeagueGroup[]

  @@unique([regionId, name])
  @@map("league_levels")
}

model LeagueGroup {
  id            Int    @id @default(autoincrement())
  leagueLevelId Int    @map("league_level_id")
  name          String // "Grupa 2"

  leagueLevel LeagueLevel @relation(fields: [leagueLevelId], references: [id])
  clubs       Club[]

  @@unique([leagueLevelId, name])
  @@map("league_groups")
}

// ============================================================
// UŻYTKOWNICY
// ============================================================

enum UserRole {
  CLUB
  PLAYER
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  role         UserRole
  isVerified   Boolean  @default(false) @map("is_verified")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  club                     Club?
  player                   Player?
  conversationParticipants ConversationParticipant[]
  sentMessages             Message[]
  notifications            Notification[]

  @@map("users")
}

// ============================================================
// PROFILE
// ============================================================

model Club {
  id            String  @id @default(uuid()) @db.Uuid
  userId        String  @unique @map("user_id") @db.Uuid
  name          String  @db.VarChar(200)
  logoUrl       String? @map("logo_url") @db.VarChar(500)
  description   String?
  city          String? @db.VarChar(100)
  regionId      Int?    @map("region_id")
  leagueGroupId Int?    @map("league_group_id")
  contactEmail  String? @map("contact_email") @db.VarChar(255)
  contactPhone  String? @map("contact_phone") @db.VarChar(20)
  website       String? @db.VarChar(300)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user                 User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  region               Region?               @relation(fields: [regionId], references: [id])
  leagueGroup          LeagueGroup?          @relation(fields: [leagueGroupId], references: [id])
  sparingOffers        SparingOffer[]
  sparingApplications  SparingApplication[]
  events               Event[]

  @@map("clubs")
}

enum FootPreference {
  LEFT
  RIGHT
  BOTH
}

enum PlayerPosition {
  GK
  CB
  LB
  RB
  CDM
  CM
  CAM
  LM
  RM
  LW
  RW
  ST
}

model Player {
  id                String          @id @default(uuid()) @db.Uuid
  userId            String          @unique @map("user_id") @db.Uuid
  firstName         String          @map("first_name") @db.VarChar(100)
  lastName          String          @map("last_name") @db.VarChar(100)
  dateOfBirth       DateTime?       @map("date_of_birth") @db.Date
  photoUrl          String?         @map("photo_url") @db.VarChar(500)
  city              String?         @db.VarChar(100)
  regionId          Int?            @map("region_id")
  heightCm          Int?            @map("height_cm")
  weightKg          Int?            @map("weight_kg")
  preferredFoot     FootPreference? @map("preferred_foot")
  primaryPosition   PlayerPosition? @map("primary_position")
  secondaryPosition PlayerPosition? @map("secondary_position")
  bio               String?
  createdAt         DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  region            Region?           @relation(fields: [regionId], references: [id])
  careerEntries     CareerEntry[]
  eventApplications EventApplication[]

  @@map("players")
}

model CareerEntry {
  id        String   @id @default(uuid()) @db.Uuid
  playerId  String   @map("player_id") @db.Uuid
  clubName  String   @map("club_name") @db.VarChar(200)
  season    String   @db.VarChar(20) // "2024/2025"
  notes     String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@map("career_entries")
}

// ============================================================
// SPARINGI
// ============================================================

enum SparingStatus {
  OPEN
  MATCHED
  CANCELLED
  COMPLETED
}

enum ApplicationStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model SparingOffer {
  id            String        @id @default(uuid()) @db.Uuid
  clubId        String        @map("club_id") @db.Uuid
  title         String        @db.VarChar(300)
  description   String?
  matchDate     DateTime      @map("match_date") @db.Timestamptz
  location      String?       @db.VarChar(300)
  lat           Decimal?      @db.Decimal(9, 6)
  lng           Decimal?      @db.Decimal(9, 6)
  costSplitInfo String?       @map("cost_split_info") @db.VarChar(500)
  status        SparingStatus @default(OPEN)
  regionId      Int?          @map("region_id")
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  club         Club                 @relation(fields: [clubId], references: [id], onDelete: Cascade)
  region       Region?              @relation(fields: [regionId], references: [id])
  applications SparingApplication[]

  @@index([regionId, status])
  @@index([matchDate])
  @@map("sparing_offers")
}

model SparingApplication {
  id              String            @id @default(uuid()) @db.Uuid
  sparingOfferId  String            @map("sparing_offer_id") @db.Uuid
  applicantClubId String            @map("applicant_club_id") @db.Uuid
  message         String?
  status          ApplicationStatus @default(PENDING)
  createdAt       DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  sparingOffer  SparingOffer @relation(fields: [sparingOfferId], references: [id], onDelete: Cascade)
  applicantClub Club         @relation(fields: [applicantClubId], references: [id], onDelete: Cascade)

  @@unique([sparingOfferId, applicantClubId])
  @@map("sparing_applications")
}

// ============================================================
// WYDARZENIA
// ============================================================

enum EventType {
  OPEN_TRAINING
  RECRUITMENT
}

model Event {
  id              String    @id @default(uuid()) @db.Uuid
  clubId          String    @map("club_id") @db.Uuid
  type            EventType
  title           String    @db.VarChar(300)
  description     String?
  eventDate       DateTime  @map("event_date") @db.Timestamptz
  location        String?   @db.VarChar(300)
  lat             Decimal?  @db.Decimal(9, 6)
  lng             Decimal?  @db.Decimal(9, 6)
  maxParticipants Int?      @map("max_participants")
  regionId        Int?      @map("region_id")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  club         Club               @relation(fields: [clubId], references: [id], onDelete: Cascade)
  region       Region?            @relation(fields: [regionId], references: [id])
  applications EventApplication[]

  @@index([regionId, type])
  @@index([eventDate])
  @@map("events")
}

model EventApplication {
  id        String            @id @default(uuid()) @db.Uuid
  eventId   String            @map("event_id") @db.Uuid
  playerId  String            @map("player_id") @db.Uuid
  message   String?
  status    ApplicationStatus @default(PENDING)
  createdAt DateTime          @default(now()) @map("created_at") @db.Timestamptz

  event  Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([eventId, playerId])
  @@map("event_applications")
}

// ============================================================
// POWIADOMIENIA
// ============================================================

enum NotificationType {
  SPARING_APPLICATION    // ktoś zaaplikował na Twój sparing
  SPARING_ACCEPTED       // Twoja aplikacja zaakceptowana
  SPARING_REJECTED       // Twoja aplikacja odrzucona
  EVENT_APPLICATION      // ktoś zgłosił się na Twoje wydarzenie
  EVENT_ACCEPTED         // Twoje zgłoszenie zaakceptowane
  EVENT_REJECTED         // Twoje zgłoszenie odrzucone
  NEW_MESSAGE            // nowa wiadomość
}

model Notification {
  id        String           @id @default(uuid()) @db.Uuid
  userId    String           @map("user_id") @db.Uuid
  type      NotificationType
  title     String           @db.VarChar(300)
  message   String?          @db.VarChar(500)
  link      String?          @db.VarChar(500)
  read      Boolean          @default(false)
  createdAt DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ============================================================
// WIADOMOŚCI
// ============================================================

model Conversation {
  id        String   @id @default(uuid()) @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  participants ConversationParticipant[]
  messages     Message[]

  @@map("conversations")
}

model ConversationParticipant {
  conversationId String @map("conversation_id") @db.Uuid
  userId         String @map("user_id") @db.Uuid

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@map("conversation_participants")
}

model Message {
  id             String    @id @default(uuid()) @db.Uuid
  conversationId String    @map("conversation_id") @db.Uuid
  senderId       String    @map("sender_id") @db.Uuid
  content        String
  readAt         DateTime? @map("read_at") @db.Timestamptz
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       User         @relation(fields: [senderId], references: [id])

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}
